<apex:page
    controller="AgentBlueprintPageController"
    showHeader="false"
    sidebar="false"
    standardStylesheets="false"
    docType="html-5.0"
    applyHtmlTag="false"
    applyBodyTag="false"
    cache="false"
    title="GNAI — Agent blueprints"
>
    <html xmlns="http://www.w3.org/1999/xhtml" lang="en">
        <head>
            <meta charset="utf-8" />
            <meta name="viewport" content="width=device-width, initial-scale=1" />
            <title>GNAI — Agent blueprints</title>
            <meta name="description" content="Copy-paste wording for Gemini web agents — hosted in Salesforce" />
            <link rel="preconnect" href="https://fonts.googleapis.com" />
            <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
            <link
                href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap"
                rel="stylesheet"
            />
            <apex:stylesheet value="{!URLFOR($Resource.GnaiAgentBlueprintsStyles)}" />
            <script type="text/javascript">
                window.__REMOTE_SEED__ = '{!$RemoteAction.AgentBlueprintPageController.seedFromStaticResource}';
                window.__REMOTE_CREATE__ = '{!$RemoteAction.AgentBlueprintPageController.createBlueprintRemote}';
            </script>
        </head>
        <body>
            <pre id="agents-json-b64">{!agentsJsonBase64}</pre>

            <div class="vf-admin-bar" role="region" aria-label="Data admin">
                <strong>Salesforce</strong>
                <button type="button" onclick="vfInvokeSeed(false);">Seed if empty</button>
                <button type="button" onclick="vfInvokeSeed(true);">Replace from seed</button>
                <label>
                    Create (JSON)
                    <textarea id="vf-create-json" rows="2" cols="36" placeholder='{"id":"slug","agentName":"...",...}'></textarea>
                </label>
                <button type="button" onclick="vfInvokeCreate();">Create draft</button>
            </div>

            <div class="layout">
                <aside class="sidebar">
                    <div class="brand">
                        <div class="brand-mark">G</div>
                        <div>
                            <h1>Agent blueprints</h1>
                            <span>Gemini web agents · Salesforce</span>
                        </div>
                    </div>

                    <div class="filter-block">
                        <label>Category</label>
                        <p class="filter-hint" id="category-filter-hint">
                            Multi-select (OR): blueprints in <strong>any</strong> chosen category. “All categories” resets.
                        </p>
                        <div class="chip-row" id="category-chips" role="group" aria-labelledby="category-filter-hint"></div>
                    </div>

                    <div class="filter-block">
                        <label>Tags</label>
                        <p class="filter-hint" id="tag-filter-hint">
                            Multi-select (OR): blueprints with <strong>any</strong> chosen tag. “All tags” resets.
                        </p>
                        <div class="chip-row" id="tag-chips" role="group" aria-labelledby="tag-filter-hint"></div>
                    </div>

                    <div class="sidebar-footer">
                        <div class="sidebar-footer-title">Salesforce hosted</div>
                        <ul class="sidebar-bullets">
                            <li>
                                Copy each field from a blueprint into the Gemini <strong>web agent builder</strong> (Name,
                                Description, Instructions, Model, Knowledge, Personalization).
                            </li>
                            <li>
                                <strong>Knowledge</strong> here is only <strong>guidance on what to upload</strong> in
                                Gemini—upload the actual files in Gemini’s Knowledge step.
                            </li>
                            <li>
                                <strong>Personalization</strong> holds <strong>example / helper prompts</strong> to try
                                after the agent exists.
                            </li>
                        </ul>
                    </div>
                </aside>

                <div class="main">
                    <section class="howto-panel" aria-labelledby="howto-heading">
                        <h2 id="howto-heading">How to use this site</h2>
                        <ul class="howto-list">
                            <li>In <strong>Gemini</strong>, start <strong>Create / web agent</strong> (or your org’s agent builder flow).</li>
                            <li>Open a blueprint below, then <strong>copy each field</strong> into the matching builder fields.</li>
                            <li>
                                <strong>Knowledge</strong> — use the text as a checklist of <strong>what to upload</strong> in
                                Gemini’s Knowledge step (this site does not host files).
                            </li>
                            <li>
                                <strong>Personalization</strong> — paste <strong>example / helper prompts</strong> so users
                                get <strong>starter questions</strong> that fit this agent after it is created.
                            </li>
                            <li>Other fields map directly to the agent builder (name, description, instructions, model).</li>
                        </ul>
                    </section>
                    <header class="top-bar">
                        <div class="search-wrap">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                            <input type="search" id="search" placeholder="Search blueprints, tags, instructions…" autocomplete="off" />
                        </div>
                        <span class="count-pill" id="count-pill"><strong>0</strong> blueprints</span>
                        <div class="top-actions">
                            <button type="button" class="btn-icon" id="theme-toggle" title="Toggle theme" aria-label="Toggle light and dark theme">
                                <span id="theme-icon">◐</span>
                            </button>
                        </div>
                    </header>

                    <div class="content">
                        <div class="grid" id="card-grid">
                            <p class="grid-placeholder" id="grid-placeholder">Loading blueprints…</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="toast" id="toast" role="status"><span class="ok">Copied</span> to clipboard</div>

            <dialog id="detail-dialog" aria-labelledby="dialog-title">
                <div class="modal-head">
                    <h3 id="dialog-title"></h3>
                    <div class="dialog-tags" id="dialog-tags" aria-label="Tags"></div>
                </div>
                <div class="modal-scroll" id="dialog-fields"></div>
                <div class="modal-actions">
                    <button type="button" class="btn-close" data-close="true">Close</button>
                    <button type="button" class="btn btn-ghost" id="dialog-copy-all">Copy all</button>
                </div>
            </dialog>

            <apex:includeScript value="{!URLFOR($Resource.GnaiAgentBlueprintsApp)}" loadOnReady="true" />
        </body>
    </html>
</apex:page>
